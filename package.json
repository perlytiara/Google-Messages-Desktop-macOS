{
  "name": "messages",
  "version": "1.6.0",
  "main": "main.js",
  "description": "Unofficial Google Messages desktop client for macOS with native notifications.",
  "author": "perlytiara",
  "repository": {
    "type": "git",
    "url": "https://github.com/perlytiara/Google-Messages-Desktop-macOS.git"
  },
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "install:app": "bash scripts/install-messages.sh",
    "dist": "node build-script.js",
    "dist:arm64": "electron-builder --mac dmg --arm64 -p never",
    "dist:x64": "electron-builder --mac dmg --x64 -p never",
    "test:notifications": "bash scripts/run-notification-tests.sh",
    "test:sms": "node scripts/send-test-sms.js"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.perlytiara.messages",
    "productName": "Messages",
    "publish": null,
    "files": [
      "**/*",
      "!**/.env",
      "!**/test-sms.json"
    ],
    "mac": {
      "category": "public.app-category.utilities",
      "icon": "assets/google-messages-icon.icns",
      "extendInfo": {
        "CFBundleDisplayName": "Messages"
      },
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "dmg": {
      "title": "${productName} ${version}"
    }
  }
}
