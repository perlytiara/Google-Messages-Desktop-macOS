# Twilio test SMS (optional). Copy to ~/Library/Application Support/messages/.env
# or set in Testing → Configure Test SMS Settings (test-sms.json).

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# E.164 phone (+1...) or alphanumeric sender ID (e.g. TESTunit)
TWILIO_FROM_SENDER=TESTunit
TEST_SMS_TO_NUMBER=
